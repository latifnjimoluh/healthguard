DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change_me
DB_NAME=healthguard

# PIN local utilisé pour dériver la clé de chiffrement SQLite.
# En local, gardez une valeur stable pour conserver la capacité
# de relire les champs chiffrés après redémarrage.
HEALTHGUARD_LOCAL_PIN=123456

# Sel stable de dérivation. A personnaliser pour un environnement réel.
HEALTHGUARD_ENCRYPTION_SALT=healthguard_local_salt_v1
